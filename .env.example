# ==========================================================================
# Configuración de PartsBot — copia este archivo a .env y completa los valores
# ==========================================================================

# --- Base de datos ---
# PostgreSQL (producción/Docker):
# DATABASE_URL=postgresql+psycopg2://postgres:admin123@localhost:5432/repuestos_db
# Si se deja vacío se usa SQLite local (desarrollo):
DATABASE_URL=

# --- Seguridad / JWT ---
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Credenciales CassChoice (sesión Frappe) ---
CASS_SID=
CASS_TOKEN=

# --- Login automático a CassChoice (alternativa a copiar SID/TOKEN a mano) ---
# Si defines usuario y contraseña, el sistema obtiene el SID y el CSRF token solo.
CASS_USUARIO=tu_usuario@correo.com
CASS_PASSWORD=tu_contraseña
CASS_BASE_URL=https://merchant.casschoice.com

# --- Crawl masivo / paginación (extracción total del catálogo) ---
# Endpoint de LISTADO/BÚSQUEDA paginada de piezas.
# IMPORTANTE: query_commodity NO lista el catálogo completo sin números de parte.
# Debes usar el endpoint de listado masivo real que devuelve miles de piezas.
# Ver partes.md en el repo para el formato de respuesta esperado (message.data
# con fields: results, total, page, page_size, total_pages, has_next).
# Si no conoces el endpoint, consulta la doc de CassChoice o usa las DevTools
# del navegador (pestaña Network) para capturar el request cuando navegues el
# catálogo completo en https://merchant.casschoice.com
# Ejemplo: /api/method/merchant_app.api.product.ProductController.search_products
CASS_SEARCH_ENDPOINT=
# Tamaño de página para el crawl (cuántas piezas por request).
CASS_PAGE_SIZE=50
# Nombres de los parámetros de paginación que espera el BODY de la petición.
CASS_PARAM_PAGE=page
CASS_PARAM_PAGE_SIZE=pageSize
# Nombres de los campos de paginación en la RESPUESTA del API (se auto-detectan
# varios alias como total_pages/totalPages y has_next/hasNext; ajusta si difieren).
CASS_FIELD_TOTAL=total
CASS_FIELD_TOTAL_PAGES=total_pages
CASS_FIELD_HAS_NEXT=has_next
CASS_FIELD_RESULTS=results

# --- Resiliencia (reintentos ante micro-cortes del servidor) ---
# Reintentos con backoff exponencial + jitter (solo para errores 5xx / red).
CASS_MAX_RETRIES=4
CASS_BACKOFF_BASE=1.5
CASS_BACKOFF_MAX=30

# --- Negocio ---
# Margen sobre precio FOB (0.06 = 6%)
MARGEN_GANANCIA=0.06
MONEDA_PRECIO=USD

# --- IA (opcional, para completar marcas chinas) ---
GEMINI_API_KEY=

# --- App ---
API_BASE_URL=http://localhost:8000
